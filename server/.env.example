# 服务端口
# 注意：Chrome 禁止访问部分端口（如 6000、6667 等），插件会报 Failed to fetch
# 推荐：3000、6080、8080、9000 等
PORT=6080

# Git 仓库（云服务器上的远程地址，使用 HTTPS + Token）
GIT_REPO_URL=https://github.com/your-org/your-repo.git
GIT_ACCESS_TOKEN=ghp_xxxxxxxxxxxx
# 基线分支：任务从此分支拉最新代码，成功后自动合并回此分支（需 AUTO_MERGE_TO_DEFAULT_BRANCH=true）
GIT_DEFAULT_BRANCH=test
GIT_AUTHOR_NAME=AI Runtime Bot
GIT_AUTHOR_EMAIL=ai-runtime@company.com

# 本地 Git 仓库路径（支持相对路径和绝对路径，Windows/Linux 均可）
# Windows 示例: D:/project/repo
# Linux 示例:   /data/repos/my-project
WORKSPACE_DIR=./workspace

# Claude Code CLI（需求整理 + 编码 Plan/执行 共用；模型和 Key 见 ~/.claude/settings.json）
CLAUDE_CLI_PATH=claude
# CLAUDE_MODEL=MiniMax-M3
CLAUDE_TIMEOUT_MS=600000
# 需求整理超时（纯文字，默认 3 分钟）
REQUIREMENT_ANALYZE_TIMEOUT_MS=180000
CLAUDE_PERMISSION_MODE=acceptEdits

# 是否自动推送到远程（生产环境建议 true）
AUTO_PUSH=true

# 是否推送 feature 分支（plugin-fix/*）到远端
# 默认 false：只推送 GIT_DEFAULT_BRANCH（例如 test）
PUSH_FEATURE_BRANCH=false

# 自动化提交跳过 husky/commitlint（pre-commit lint-staged 仍会执行）
GIT_SKIP_HOOKS=true

# 任务成功后自动合并到 GIT_DEFAULT_BRANCH 并推送（无需人工 MR）
AUTO_MERGE_TO_DEFAULT_BRANCH=true

# 允许的来源（CORS，浏览器插件 origin 为 chrome-extension://xxx）
CORS_ORIGIN=*

# 截图上传目录（相对 server 工作目录）
UPLOAD_DIR=./data/uploads
# 单张图片上限（字节），客户端会压缩到约 100-200KB
UPLOAD_MAX_BYTES=307200
# 每个任务最多图片数
UPLOAD_MAX_COUNT=3
