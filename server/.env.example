# 服务端口（Chrome 会拦截 6000 等端口，推荐 6080/8080）
PORT=6080

# Git 仓库（必填）
GIT_REPO_URL=https://github.com/your-org/your-repo.git
GIT_ACCESS_TOKEN=ghp_xxxxxxxxxxxx
GIT_DEFAULT_BRANCH=test
GIT_AUTHOR_NAME=AI Runtime Bot
GIT_AUTHOR_EMAIL=ai-runtime@company.com

# 本地 Git 仓库路径（必填）
WORKSPACE_DIR=./workspace

# Claude Code CLI（模型和 Key 由 ~/.claude/settings.json 或 cc-switch 配置）
CLAUDE_CLI_PATH=claude
CLAUDE_TIMEOUT_MS=1200000
CLAUDE_PERMISSION_MODE=acceptEdits
CLAUDE_SKIP_PERMISSIONS=true
CLAUDE_SETTING_SOURCES=user,project

# Git 自动化
AUTO_PUSH=true
GIT_SKIP_HOOKS=true
AUTO_MERGE_TO_DEFAULT_BRANCH=true

# CORS（浏览器插件 origin 为 chrome-extension://xxx）
CORS_ORIGIN=*

# TAPD Open API（可选；应用 ID + 密钥来自 o.tapd.cn 开发者后台）
TAPD_API_BASE=https://api.tapd.cn
TAPD_CLIENT_ID=
TAPD_CLIENT_SECRET=
TAPD_WORKSPACE_ID=
